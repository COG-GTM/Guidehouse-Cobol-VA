           END-IF.
      
           IF (DB-FUNCTION-TYPE = 'FIND CURR')
              GO TO 0000-EXIT
           END-IF.
      
           IF ((DB-FUNCTION-TYPE = 'FETCH NEXT') AND DB-CLOSE)
              MOVE 'FETCH FIRST' TO DB-FUNCTION-TYPE
