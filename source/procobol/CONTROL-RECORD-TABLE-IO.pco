               WHEN 'SELECT'
                   IF (DB-FUNCTION-TYPE = 'FETCH CURR')
                      MOVE DB-ROWID         TO W-ROWID-K 
                      MOVE W-DB-ROWID-KEY   TO W-DB-WHERE
