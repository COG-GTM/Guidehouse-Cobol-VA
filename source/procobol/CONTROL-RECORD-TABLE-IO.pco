           IF  DB-FUNCTION      = 'SELECT DUMMY'
           AND DB-FUNCTION-TYPE = 'OWNER'
               MOVE 'SELECT' TO DB-FUNCTION
               MOVE 'FETCH OWNER' TO DB-FUNCTION-TYPE
           END-IF.
      
