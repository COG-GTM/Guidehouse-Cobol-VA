                   IF (DB-FUNCTION-TYPE = 'FETCH FIRST' OR 'FETCH' OR
                                          'FETCH DBK'   OR 'FIND DBK')
                      MOVE CONTROL-RECORD-NAME TO
                          WCONTROL-RECORD-NAME-K
                      MOVE CONTROL-RECORD-NUMBER TO
                          WCONTROL-RECORD-NUMBER-K
                      MOVE W-DB-PRIMARY-KEY   TO W-DB-WHERE
                      MOVE SPACES             TO W-DB-ORDERBY
                   END-IF
                   IF DB-FUNCTION-TYPE = 'FETCH OWNER'
                      MOVE DB-CONSTRAINT TO DB-CONSTRAINT-PKEYS
                      MOVE CONTROL-RECORD-NAME-PK TO
                         WCONTROL-RECORD-NAME-K
                      MOVE CONTROL-RECORD-NUMBER-PK TO
                         WCONTROL-RECORD-NUMBER-K
                      MOVE W-DB-PRIMARY-KEY   TO W-DB-WHERE
                   END-IF
                   IF DB-FUNCTION-TYPE = 'FETCH NEXT'
                      PERFORM FETCH-DB     THRU FETCH-DB-EXIT
                   ELSE
                      IF  DB-FUNCTION-TYPE = 'FETCH FIRST' 
                      AND DB-SET-NAME = SPACES
                         INSPECT W-DB-WHERE REPLACING ALL 'XXXXX'
                                                          BY GT-EQ-OP
                      ELSE
                         INSPECT W-DB-WHERE REPLACING ALL 'XXXXX'
                                                          BY EQ-OP
                      END-IF
                      PERFORM OPN-DB       THRU OPN-DB-EXIT
                      PERFORM FETCH-DB     THRU FETCH-DB-EXIT
                   END-IF
                   IF DB-OK
                       PERFORM 2000-MOVE-DATA-BACK THRU 2000-EXIT
                   END-IF
               WHEN 'INSERT'
                   PERFORM 1000-MOVE-DATA THRU 1000-EXIT
                   PERFORM INSERT-DB    THRU INSERT-DB-EXIT
