       PROCEDURE DIVISION USING DB-TABLE-NAME
                                DB-FUNCTION
                                DB-FUNCTION-TYPE
                                DB-SET-NAME
                                DB-DATA
                                DB-ROWID
                                DB-MISC
                                DB-RETURN-CODE
                                DB-MESSAGE
